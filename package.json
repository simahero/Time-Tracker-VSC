{
  "name": "time-tracker",
  "displayName": "Time Tracker",
  "description": "Tracks time spent on a project, updates a database every minute, and shows time in the status bar.",
  "version": "0.0.3",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "time-tracker.syncToLocalFile",
        "title": "Sync Time Tracker Data to Local File"
      },
      {
        "command": "time-tracker.loadFromLocalFile",
        "title": "Load Time Tracker Data from Local File"
      },
      {
        "command": "time-tracker.searchProjects",
        "title": "Filter Projects",
        "icon": "$(search)"
      },
      {
        "command": "time-tracker.toggleViewMode",
        "title": "Toggle Daily/Monthly",
        "icon": "$(calendar)"
      },
      {
        "command": "time-tracker.toggleUnit",
        "title": "Toggle Minutes/Hours",
        "icon": "$(clock)"
      },
      {
        "command": "time-tracker.deleteProject",
        "title": "Delete Project",
        "icon": "$(trash)"
      },
      {
        "command": "time-tracker.deleteEntry",
        "title": "Delete Entry",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "time-tracker.searchProjects",
          "when": "view == timeTrackerProjects",
          "group": "navigation"
        },
        {
          "command": "time-tracker.clearSearch",
          "when": "view == timeTrackerProjects",
          "group": "navigation"
        },
        {
          "command": "time-tracker.toggleViewMode",
          "when": "view == timeTrackerProjects",
          "group": "navigation"
        },
        {
          "command": "time-tracker.toggleUnit",
          "when": "view == timeTrackerProjects",
          "group": "navigation"
        },
        {
          "command": "time-tracker.deleteProject",
          "when": "false",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "time-tracker.deleteProject",
          "when": "view == timeTrackerProjects && viewItem == project",
          "group": "inline"
        },
        {
          "command": "time-tracker.deleteEntry",
          "when": "view == timeTrackerProjects && viewItem == entry",
          "group": "inline"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "timeTrackerViewContainer",
          "title": "Time Tracker",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "timeTrackerViewContainer": [
        {
          "id": "timeTrackerProjects",
          "name": "Tracked Projects"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.100.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3",
    "ts-loader": "^9.5.2",
    "webpack": "^5.99.7",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2"
  }
}